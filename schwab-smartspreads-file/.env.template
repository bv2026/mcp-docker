# Copy this to schwab-smartspreads-file/.env and fill in real values.
# .env is gitignored — never commit credentials.

SCHWAB_CLIENT_ID=your_app_client_id_here
SCHWAB_CLIENT_SECRET=your_app_client_secret_here
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
SCHWAB_DB_PATH=/app/config/smartspreads.db
SCHWAB_DASHBOARD_PORT=8765

# File-based keyring (required in Docker — no system keychain available)
PYTHON_KEYRING_BACKEND=keyrings.alt.file.PlaintextKeyring
# Token will be stored at /app/config/python_keyring (inside the config volume)
KEYRING_PROPERTY_FILENAME=/app/config/python_keyring
