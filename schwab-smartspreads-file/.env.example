# Copy to .env and fill in real Schwab API credentials
SCHWAB_CLIENT_ID=your_client_id_here
SCHWAB_CLIENT_SECRET=your_client_secret_here
SCHWAB_CALLBACK_URL=https://127.0.0.1:5000/auth/callback
SCHWAB_DASHBOARD_PORT=8766

# Container paths (do not change)
SCHWAB_TOKEN_PATH=/app/config/token.json
SCHWAB_DB_PATH=/app/config/smartspreads.db
SCHWAB_TOS_STATEMENT_PATH=/app/config/tos-statement.csv
TOS_STATEMENT_PATH=/app/config/tos-statement.csv
SCHWAB_WATCHLIST_CONFIG=/data/smartspreads/published/watchlist.yaml
